# ============================================================
# Matcha Multi Monitor .env example
# Copy this file to .env and adjust the values you need.
# ============================================================

# Sites to check. Supported profiles: horii, koyamaen, ippodo
SITE_PROFILES=horii,koyamaen,ippodo

# Run mode
RUN_ONCE=true
CHECK_INTERVAL_SECONDS=600
SINGLE_INSTANCE=true
# Random extra seconds (0..N) added to each wait so checks don't hit sites at fixed times
LOOP_JITTER_SECONDS=30

# Networking / politeness
# Verify TLS certificates. Keep true; only set false if a site has a broken cert.
VERIFY_SSL=true
# Retries with exponential backoff on transient HTTP errors (429/5xx) and timeouts
HTTP_MAX_RETRIES=3
# Delay between consecutive product-detail requests within one site (seconds)
REQUEST_DELAY_SECONDS=0.5
# Max sites checked in parallel (each site uses its own HTTP session)
MAX_SITE_WORKERS=4

# Log rotation (per file)
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Monitoring behavior
AUTO_ADD_TO_CART=true
ALERT_WHEN_ANY_IN_STOCK=true
ALERT_ON_UNKNOWN_STOCK=false
SUMMARY_ALERT_EVERY_RUN=false
ENABLE_LOGIN=false
TARGET_COUNTRY_NAME=Taiwan
TARGET_COUNTRY_CODE=TW

# Log files
LOG_FILE=matcha_multi_monitor.log
LOG_DIR=logs
LOCK_FILE=matcha_multi_monitor.lock
ALERT_STATE_FILE=logs/matcha_alert_state.json

# Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_VERIFY_SSL=false
ENABLE_LOCAL_NOTIFICATION=true
TEST_TELEGRAM=false
SIMULATE_IN_STOCK=false

# ============================================================
# Horii Shichimeien
# ============================================================
HORII_ENABLED=true
HORII_LOGIN_EMAIL=
HORII_LOGIN_PASSWORD=
HORII_USE_SHOPIFY_PRODUCTS_JSON=true
HORII_TARGET_PRODUCT_NAMES=
HORII_TARGET_PRODUCT_URLS=
# HORII_PRODUCT_URL=https://horiishichimeien.com/collections/all?selected=%E6%8A%B9%E8%8C%B6
# HORII_SHOPIFY_PRODUCTS_JSON_URL=https://horiishichimeien.com/collections/%E6%8A%B9%E8%8C%B6/products.json?limit=250
# HORII_SHIPPING_CHECK_URLS=https://horiishichimeien.com/cart,https://horiishichimeien.com/pages/international-orders,https://horiishichimeien.com/pages/shipping

# ============================================================
# Marukyu Koyamaen
# ============================================================
KOYAMAEN_ENABLED=true
# Koyamaen 要登入才看得到「寄送台灣」的國家選項；建議只對這一站開登入。
# 全域 ENABLE_LOGIN 維持 false，避免 Ippodo/Horii(Shopify)做注定失敗的自動登入。
KOYAMAEN_ENABLE_LOGIN=true
KOYAMAEN_LOGIN_EMAIL=
KOYAMAEN_LOGIN_PASSWORD=
KOYAMAEN_TARGET_PRODUCT_NAMES=Yugen,Chigi no Shiro,Isuzu,Aoarashi,Wako
KOYAMAEN_TARGET_PRODUCT_URLS=https://www.marukyu-koyamaen.co.jp/english/shop/products/1f6d000cc,https://www.marukyu-koyamaen.co.jp/english/shop/products/1gaf000cc
# KOYAMAEN_PRODUCT_URL=https://www.marukyu-koyamaen.co.jp/english/shop/products/catalog/matcha/principal
# KOYAMAEN_SHIPPING_CHECK_URLS=https://www.marukyu-koyamaen.co.jp/english/shop/cart,https://www.marukyu-koyamaen.co.jp/english/shop/account/account-addresses

# ============================================================
# Ippodo Tea Global
# ============================================================
IPPODO_ENABLED=true
IPPODO_LOGIN_EMAIL=
IPPODO_LOGIN_PASSWORD=
IPPODO_TARGET_PRODUCT_NAMES=
IPPODO_TARGET_PRODUCT_URLS=https://global.ippodo-tea.co.jp/collections/matcha/products/matcha5010331,https://global.ippodo-tea.co.jp/collections/matcha/products/matcha5010431,https://global.ippodo-tea.co.jp/collections/matcha/products/matcha6105023,https://global.ippodo-tea.co.jp/collections/matcha/products/matcha5010931,https://global.ippodo-tea.co.jp/collections/matcha/products/matcha5010831,https://global.ippodo-tea.co.jp/collections/matcha/products/matcha5018231
# IPPODO_PRODUCT_URL=https://global.ippodo-tea.co.jp/collections/matcha
# IPPODO_SHIPPING_CHECK_URLS=https://global.ippodo-tea.co.jp/cart,https://global.ippodo-tea.co.jp/account/addresses
